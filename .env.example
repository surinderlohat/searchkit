# Copy this to .env and fill in your values
# cp .env.example .env

# ChromaDB
CHROMA_PERSIST_DIR=/app/chromadb
DEFAULT_COLLECTION=default

# Embedding model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SENTENCE_TRANSFORMERS_HOME=/app/models
EMBEDDING_DEVICE=auto           # auto | cpu | cuda

# Logging
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                 # text (dev) | json (prod)
MEMORY_WARN_MB=3500           # warn in logs when RAM exceeds this
MEMORY_LIMIT_MB=4000          # reject writes when RAM exceeds this
